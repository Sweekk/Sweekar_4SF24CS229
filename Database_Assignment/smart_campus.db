SELECT s.reg_number, s.full_name, h.hostel_name, r.room_number, r.monthly_fee
FROM students s
JOIN allocations a ON s.student_id = a.student_id AND a.status = 'Active'
JOIN rooms r       ON a.room_id    = r.room_id
JOIN hostels h     ON r.hostel_id  = h.hostel_id;


SELECT h.hostel_name, SUM(p.amount) AS total_collected
FROM payments p
JOIN allocations a ON p.allocation_id = a.allocation_id
JOIN rooms r       ON a.room_id       = r.room_id
JOIN hostels h     ON r.hostel_id     = h.hostel_id
GROUP BY h.hostel_name;


SELECT h.hostel_name, a.amenity_name
FROM hostels h
JOIN hostel_amenities ha ON h.hostel_id  = ha.hostel_id
JOIN amenities a         ON ha.amenity_id = a.amenity_id
ORDER BY h.hostel_name;


SELECT s.full_name, h.hostel_name, r.monthly_fee AS amount_due
FROM allocations a
JOIN students s ON a.student_id = s.student_id
JOIN rooms r    ON a.room_id    = r.room_id
JOIN hostels h  ON r.hostel_id  = h.hostel_id
WHERE a.status = 'Active'
  AND a.allocation_id NOT IN (
      SELECT allocation_id FROM payments
      WHERE payment_date BETWEEN '2024-08-01' AND '2024-08-31'
  );

